# =============================================================
#  ORTAM DEĞİŞKENLERİ ÖRNEĞİ
#  Bu dosyayı .env olarak kopyalayıp gerçek değerleri girin.
#  .env dosyası ASLA GitHub'a gönderilmez (gizli kalır).
# =============================================================

# Veritabanı
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ajans?schema=public"

# Redis (BullMQ arka plan görevleri)
REDIS_URL="redis://localhost:6379"

# NextAuth
AUTH_SECRET="degistirin-uzun-rastgele-bir-deger"
AUTH_URL="http://localhost:3000"

# Yapay zekâ (Anthropic)
ANTHROPIC_API_KEY=""

# Google Business / Maps
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_MAPS_API_KEY=""

# Ödeme - PayTR
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""

# Ödeme - Stripe (gelecekte)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# E-posta (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="bildirim@ajans.com"

# Uygulama
APP_URL="http://localhost:3000"
